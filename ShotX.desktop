[Desktop Entry]
Name=ShotX
GenericName=Screenshot Tool
Comment=ShareX clone for Linux with Wayland support
Exec=shotx
Icon=camera-photo
Terminal=false
Type=Application
Categories=Utility;Graphics;
Keywords=screenshot;capture;sharex;
StartupNotify=true
Actions=Fullscreen;Region;Window;

[Desktop Action Fullscreen]
Name=Capture Fullscreen
Exec=shotx --capture-fullscreen

[Desktop Action Region]
Name=Capture Region
Exec=shotx --capture-region

[Desktop Action Window]
Name=Capture Window
Exec=shotx --capture-window
